# Claude Authentication (选择以下其中一种)
# 选项 1: Claude Subscription (Pro/Max)
CLAUDE_CODE_OAUTH_TOKEN=

# 选项 2: Anthropic API Key
ANTHROPIC_API_KEY=

# 选项 3: 智谱 GLM-5.0 (需要购买 GLM Coding 套餐)
GLM_API_KEY=
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5.0
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.0
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.0
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKENS=                    # Extra bots: token2:Label2,token3:Label3
TELEGRAM_ONLY=true

# Assistant Configuration
ASSISTANT_NAME=Andy

# Lume VM Configuration
LUME_VM_NAME=nanoclaw-vm
LUME_VM_IP=

# Browser Configuration
BROWSER_LANG=zh-CN
BROWSER_TIMEZONE=Asia/Shanghai

# Proxy Configuration (青果网络)
QG_AUTH_KEY=
QG_AUTH_PWD=
QG_DEFAULT_AREA=440300
QG_DEFAULT_ISP=电信
